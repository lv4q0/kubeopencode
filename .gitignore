.vscode/

# MacOS
.DS_Store

# Go
bin/
cover.out

# Built binaries
/kubeopencode

# Helm
dist/

# Node
node_modules/

# UI
ui/dist/
ui/coverage/

# OpenCode Web UI (self-hosted build artifacts)
internal/opencode-app/dist/
